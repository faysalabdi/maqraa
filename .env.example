# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (Supabase: Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_TEST_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Mistral OCR — used for PDF extraction when set.
# Falls back to Claude vision (slow, expensive) if absent.
# Get one at console.mistral.ai. ~$1 per 1000 pages.
MISTRAL_API_KEY=

# PDF book importer (`pnpm import-pdf`) reuses the Anthropic client above to
# clean + chapter-split extracted text, and reads scanned pages via vision.
# Optional: override the model it uses (defaults to ANTHROPIC_TEST_MODEL).
# ANTHROPIC_IMPORT_MODEL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — billing for Maqra Pro. Optional: the app runs free-only without these.
# Create two recurring Prices (monthly + annual) on one Product, then:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook  (for the webhook secret)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
