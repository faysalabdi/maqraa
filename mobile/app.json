{
  "expo": {
    "name": "Maqraa",
    "slug": "maqraa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maqraa",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.maqraa.ios",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.maqraa.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF6EF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f9663",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3cfbafb-dd19-4a77-99e2-3e0f8f7a25e2"
      }
    },
    "owner": "faysalabdi"
  }
}
