{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "image": "latest" }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "image": "latest" }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "image": "latest" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "SET_AFTER_ASC_APP_CREATED",
        "ascApiKeyPath": "~/.private_keys/AuthKey_REPLACE.p8",
        "ascApiKeyIssuerId": "REPLACE_ISSUER_ID",
        "ascApiKeyId": "REPLACE_KEY_ID"
      }
    }
  }
}
